{
  "name": "xmeet-ai-extension",
  "version": "1.0.0",
  "description": "XMeet AI Chrome / Edge 瀏覽器擴充功能",
  "private": true,
  "scripts": {
    "icons": "node scripts/generate-icons.cjs",
    "dev": "node scripts/generate-icons.cjs && webpack --mode=development --watch",
    "build": "node scripts/generate-icons.cjs && webpack --mode=production",
    "pack": "npm run build && cd dist && zip -r ../xmeet-ai-extension.zip . && echo 'Packed → xmeet-ai-extension.zip'"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^25.6.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "dotenv": "^16.4.5",
    "mini-css-extract-plugin": "^2.9.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
