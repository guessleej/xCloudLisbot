# ── Copy this file to .env and fill in real values ───────────────────────────

POSTGRES_PASSWORD=change_me

# HS256 signing secret for backend-issued JWTs (≥ 32 chars required in production)
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# Fernet key for encrypting calendar OAuth tokens in DB.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CALENDAR_TOKEN_ENCRYPTION_KEY=change_me_to_a_fernet_key
