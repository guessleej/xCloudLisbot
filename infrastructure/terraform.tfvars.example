# 複製此檔案為 terraform.tfvars 並填入真實值
# terraform.tfvars 已列入 .gitignore，不會被提交
#
# 使用方式：
#   cp terraform.tfvars.example terraform.tfvars
#   # 填入 subscription_id 與其他值
#   terraform init
#   terraform plan
#   terraform apply

subscription_id = "你的-Azure-Subscription-ID"
location        = "eastasia"
environment     = "prod"
openai_model    = "gpt-4"

# JWT Secret — 產生一組 ≥32 字元隨機字串(請勿沿用範例值;此檔有被 git 追蹤)：
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
jwt_secret = "REPLACE-WITH-A-32+CHAR-RANDOM-SECRET"

# Fernet Key — 執行以下指令產生：
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
calendar_token_encryption_key = ""

# Microsoft OAuth — 填入你的 Entra App 值(範本只放佔位符)
microsoft_client_id     = "YOUR-ENTRA-APP-CLIENT-ID"
microsoft_client_secret = "YOUR-ENTRA-APP-CLIENT-SECRET"
microsoft_tenant_id     = "YOUR-ENTRA-TENANT-ID"

# PostgreSQL 密碼（留空 Terraform 自動產生 32 字元隨機密碼）
pg_password = ""

# GitHub OAuth（選填，不用可留空）
github_client_id     = ""
github_client_secret = ""

# Google OAuth（選填，不用可留空）
google_client_id     = ""
google_client_secret = ""
