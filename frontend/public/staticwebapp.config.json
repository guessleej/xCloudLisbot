{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/static/*",
      "/*.{js,css,json,png,jpg,jpeg,gif,svg,ico,txt,xml,woff,woff2,ttf,eot,map,webmanifest}"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
