# Microsoft Entra ID (Azure AD)
REACT_APP_AZURE_CLIENT_ID=your-azure-client-id-here
REACT_APP_AZURE_TENANT_ID=common

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# GitHub OAuth
REACT_APP_GITHUB_CLIENT_ID=your-github-client-id

# Backend API URL (Azure Functions)
REACT_APP_BACKEND_URL=http://localhost:7071

# Environment (development enables dev-login)
REACT_APP_ENVIRONMENT=development

# App Info
REACT_APP_NAME=xCloudLisbot
REACT_APP_VERSION=2.0.0
